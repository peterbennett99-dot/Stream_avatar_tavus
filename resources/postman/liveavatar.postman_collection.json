{
  "info": {
    "name": "LiveAvatar",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "liveavatar_api_key",
      "value": "",
      "type": "string"
    },
    {
      "key": "elevenlabs_api_key",
      "value": "",
      "type": "string"
    },
    {
      "key": "base_url",
      "value": "https://api.liveavatar.com",
      "type": "string"
    },
    {
      "key": "elevenlabs_base_url",
      "value": "https://api.elevenlabs.io",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "LiveAvatar",
      "item": [
        {
          "name": "Register ElevenLabs API Key",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-KEY",
                "value": "{{liveavatar_api_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"secret_type\": \"ELEVENLABS_API_KEY\",\n  \"secret_value\": \"{{elevenlabs_api_key}}\",\n  \"secret_name\": \"ElevenLabs Agent Key\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/v1/secrets",
              "host": ["{{base_url}}"],
              "path": ["v1", "secrets"]
            },
            "description": "Registers your ElevenLabs API key as a secret in LiveAvatar. The returned `secret_id` is used when starting a LITE mode session."
          },
          "response": []
        }
      ]
    },
    {
      "name": "ElevenLabs",
      "item": [
        {
          "name": "List Voices",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "xi-api-key",
                "value": "{{elevenlabs_api_key}}"
              }
            ],
            "url": {
              "raw": "{{elevenlabs_base_url}}/v1/voices",
              "host": ["{{elevenlabs_base_url}}"],
              "path": ["v1", "voices"]
            },
            "description": "Returns all available voices. Each voice has a `voice_id` field — use that as ELEVENLABS_VOICE_ID."
          },
          "response": []
        },
        {
          "name": "Get Default Voices (no auth)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{elevenlabs_base_url}}/v1/voices?show_legacy=true",
              "host": ["{{elevenlabs_base_url}}"],
              "path": ["v1", "voices"],
              "query": [
                {
                  "key": "show_legacy",
                  "value": "true"
                }
              ]
            },
            "description": "Returns the default ElevenLabs voices without authentication. Useful for quickly browsing available voice_ids."
          },
          "response": []
        }
      ]
    }
  ]
}
